# Flux Environment Configuration Template
# Copy this file to .env and adjust values for your environment

# NETWORK_MODE: Controls how services communicate
# - 'local': Services communicate via localhost (fastest for development)
#   Use for: Local development, testing
#   URLs: http://localhost:8880 (warehouse), http://localhost:8881 (gateway), http://localhost:8882 (generator)
#
# - 'tailscale': Services communicate via Tailscale FQDN (cross-machine access)
#   Use for: Production, multi-machine testing
#   URLs: http://${MACHINE_FQDN}:8880, http://${MACHINE_FQDN}:8881, http://${MACHINE_FQDN}:8882
#   Requires: Tailscale network access from client machines
NETWORK_MODE=local

# MACHINE_FQDN: Your Tailscale machine FQDN (used when NETWORK_MODE=tailscale)
# Find your FQDN by running: tailscale status
# Example: thinkpad.antelope-centauri.ts.net
MACHINE_FQDN=thinkpad.antelope-centauri.ts.net

# KAFKA_BOOTSTRAP: Kafka bootstrap servers (always Docker internal DNS)
# Do not change unless using external Kafka
KAFKA_BOOTSTRAP=kafka:9092

# FLUX_API_KEY: API Key required for all flux service endpoints
# This protects the private data ingestion (/api/data) and query (/api/query) endpoints
# SECURITY: Change this to a secure random value for production
# Generate with: openssl rand -hex 32
FLUX_API_KEY=test-key-change-me

# Optional: Additional Spring Boot configuration
# Uncomment and adjust as needed:
# LOG_LEVEL=INFO
# SPRING_PROFILES_ACTIVE=prod
